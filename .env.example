# ── Docker Hub ───────────────────────────────────────────────────────────────
DOCKER_IMAGE=tuusuario/portfolio-api
IMAGE_TAG=latest

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_USER=portfolio_user
DB_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO
DB_NAME=api_portfolio

# ── Seguridad ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CAMBIA_ESTO_POR_UN_SECRET_LARGO_Y_ALEATORIO

# ── Cookies / CORS ───────────────────────────────────────────────────────────
COOKIE_DOMAIN=api.danielwar.tech
COOKIE_SAMESITE=lax
# Separados por comas dentro del JSON array, ej: ["https://danielwar.tech","https://www.danielwar.tech"]
BACKEND_CORS_ORIGINS=["https://danielwar.tech"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_SENDER_EMAIL=tu@email.com
SMTP_PASSWORD=tu_app_password

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
